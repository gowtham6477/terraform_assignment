# ==============================================================
# .gitignore — Terraform AWS Project
# --------------------------------------------------------------
# This file tells Git which files/folders to NEVER track.
# This is critical for security and keeping the repo clean.
# ==============================================================


# ---------------------------------------------------------------
# Terraform State Files  ← MOST IMPORTANT — never commit these!
# --------------------------------------------------------------
# terraform.tfstate contains the real IDs of every AWS resource
# you have created. It may also contain sensitive values.
# Committing it to GitHub exposes your infrastructure details.
# ---------------------------------------------------------------
*.tfstate
*.tfstate.*
*.tfstate.backup

# ---------------------------------------------------------------
# Terraform Plan Output Files
# These are binary files generated by "terraform plan -out=..."
# They are machine-specific and should not be shared.
# ---------------------------------------------------------------
*.tfplan
*.plan

# ---------------------------------------------------------------
# Terraform Working Directory
# Downloaded provider plugins live here (~40-200 MB).
# Never commit this — teammates run "terraform init" themselves.
# ---------------------------------------------------------------
.terraform/
.terraform.lock.hcl

# ---------------------------------------------------------------
# Crash & Override Files
# crash.log is written when Terraform itself crashes.
# override files are for local developer overrides only.
# ---------------------------------------------------------------
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---------------------------------------------------------------
# Sensitive Variable Files
# terraform.tfvars can contain secrets (API keys, passwords).
# Optionally ignore it — we KEEP it here since our file has
# no secrets, only region and project name.
# Uncomment the line below if you ever add secrets to it.
# ---------------------------------------------------------------
# terraform.tfvars
# *.auto.tfvars

# ---------------------------------------------------------------
# Environment / IDE Files
# These are editor-specific and not part of the project.
# ---------------------------------------------------------------
.env
.env.*
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ---------------------------------------------------------------
# AWS Credentials — NEVER commit these!
# ---------------------------------------------------------------
.aws/
credentials
